{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "rust/sdr_core/src/**",
    "android/app/src/main/java/**"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "android": {
      "cache": false,
      "persistent": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interactive": true,
      "interruptible": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  },
  "ui": "tui"
}
